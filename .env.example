# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# ── DATABASE ───────────────────────────────────────────────────────────────────
# SQLite (default, works out of the box)
DATABASE_URL=sqlite+aiosqlite:///./data/tripbot.db

# ── OPTIONAL — better exchange rates (free tier available) ─────────────────────
# Sign up at https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=

# ── OPTIONAL — OCR for receipt scanning ───────────────────────────────────────
# Sign up at https://ocr.space/ (free: 25k requests/month)
# If left empty, falls back to local pytesseract (needs tesseract installed)
OCR_SPACE_API_KEY=

# ── DEBUG ──────────────────────────────────────────────────────────────────────
DEBUG=false
